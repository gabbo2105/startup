{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true
  },
  "imports": {
    "@supabase/supabase-js": "jsr:@supabase/supabase-js@2",
    "std/assert/": "https://deno.land/std@0.224.0/assert/"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-net --allow-read tests/",
    "test:unit": "deno test --allow-env --allow-net --allow-read tests/search_test.ts tests/chat_proxy_test.ts tests/xss_test.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "lint": {
    "include": ["*.ts", "tests/"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "include": ["*.ts", "tests/"],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "semiColons": true
  },
  "exclude": [
    ".git",
    "*.html",
    "*.py",
    "*.sql",
    "*.json"
  ]
}
